{
  "name": "jiedan-zhushou",
  "version": "0.1.0",
  "description": "接单画师助手 - 本地单机版",
  "main": "electron/main.js",
  "private": true,
  "scripts": {
    "dev": "concurrently -k \"npm:dev:frontend\" \"npm:dev:electron\"",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:electron": "wait-on http://localhost:5173 && node scripts/dev-electron.js",
    "build": "npm run build:frontend && electron-builder",
    "build:frontend": "cd frontend && npm run build",
    "build:win": "npm run build:frontend && electron-builder --win",
    "postinstall": "cd frontend && npm install"
  },
  "dependencies": {
    "better-sqlite3": "^11.3.0",
    "express": "^4.21.1",
    "sharp": "^0.33.5",
    "uuid": "^10.0.0",
    "dayjs": "^1.11.13",
    "adm-zip": "^0.5.16"
  },
  "devDependencies": {
    "electron": "^32.2.0",
    "electron-builder": "^25.1.8",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.jiedan.zhushou",
    "productName": "接单助手",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "backend/**/*",
      "frontend/dist/**/*",
      "package.json"
    ],
    "extraResources": [
      "backend/schema.sql"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}